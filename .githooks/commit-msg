#!/usr/bin/env bash
# Simple commit-msg hook to enforce a conventional commit-like style
MSG_FILE="$1"
MSG=$(sed -n '1p' "$MSG_FILE" | tr -d '\n')

# Require: <type>(scope?): short summary
if ! echo "$MSG" | grep -E '^(feat|fix|docs|chore|refactor|perf|test|style)(\(.+\))?: .{1,50}' >/dev/null; then
  echo "Commit message does not follow the required pattern:" >&2
  echo "  <type>(scope?): short summary" >&2
  echo "Examples: 'feat: add widget', 'fix(parser): handle null'" >&2
  exit 1
fi

exit 0
